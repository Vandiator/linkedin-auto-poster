# Cloudinary — required
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Local gallery server port
PORT=3000

# Optional: Cloudinary AI auto-tagging (requires add-on subscription)
# Providers: google_tagging, aws_rek_tagging, imagga_tagging, cloudinary_aaa
# Enable add-on at: https://console.cloudinary.com/console/addons
CLOUDINARY_AUTOTAG_PROVIDER=
CLOUDINARY_AUTOTAG_CONFIDENCE=0.6

# OpenAI — required for carousel.js (gpt-image-2)
OPENAI_API_KEY=

# Buffer — required for schedule-linkedin-post.js
# Generate at: https://publish.buffer.com/settings/api
BUFFER_API_TOKEN=

# LinkedIn channel ID inside Buffer (run channels query to find yours)
LINKEDIN_CHANNEL_ID=
